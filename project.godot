config_version=5

[application]

config/name="Steikemann2D"
run/main_scene="res://main-world/main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://steikeprogramicon.ico"
config/windows_native_icon="res://steikeprogramicon.ico"

[autoload]

DebugMenu="*res://addons/debug_menu/debug_menu.tscn"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[editor_plugins]

enabled=PackedStringArray("res://addons/debug_menu/plugin.cfg")

